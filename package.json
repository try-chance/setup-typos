{
  "name": "setup-typos",
  "version": "0.0.1",
  "private": true,
  "description": "GitHub Action for installing crate-ci/typos",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "homepage": "https://github.com/try-chance/setup-typos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/try-chance/setup-typos.git"
  },
  "bugs": {
    "url": "https://github.com/try-chance/setup-typos/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "npm run package",
    "package": "node scripts/build.mjs",
    "package:watch": "npm run package -- --watch",
    "test": "npm run build && node --test test/*.test.mjs",
    "all": "npm run build && npm run package"
  },
  "keywords": [
    "actions",
    "github-action",
    "typos"
  ],
  "author": "Noai-oss",
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.27.0",
    "typescript": "^6.0.3"
  }
}
